page {
  background: var(--color-white-dark);
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid var(--color-gray);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 30rpx;
  color: var(--color-gray-max);
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: var(--color-primary-text);
  border-bottom-color: var(--color-primary);
  font-weight: 600;
}

.tab-content {
  padding: 20rpx;
}

.filter-block {
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.filter-input {
  width: 100%;
  height: 70rpx;
  background: var(--color-white-dark);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx 20rpx;
  margin-bottom: 15rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.info-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-black-min);
}

.detail {
  font-size: 24rpx;
  color: var(--color-gray-max);
  margin-top: 6rpx;
}

.toggle-row {
  display: flex;
  align-items: center;
}

.toggle-label {
  font-size: 26rpx;
  color: var(--color-gray-max);
  margin-right: 10rpx;
}

.app-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 25rpx 20rpx;
  margin-bottom: 15rpx;
}

.app-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.app-date {
  font-size: 24rpx;
  color: var(--color-gray-max);
}

.app-counts {
  font-size: 24rpx;
  color: var(--color-primary);
}

.app-reason {
  margin-bottom: 20rpx;
}

.reason-label {
  font-size: 26rpx;
  color: var(--color-gray-max);
}

.reason-text {
  font-size: 28rpx;
  color: var(--color-black-min);
  line-height: 1.5;
}

.app-actions {
  display: flex;
  gap: 20rpx;
}

.btn-approve {
  flex: 1;
  background: var(--color-primary);
  color: var(--color-primary-text);
  font-size: 28rpx;
  padding: 15rpx 0;
  border-radius: 8rpx;
  border: none;
  line-height: 1.2;
}

.btn-approve::after {
  border: none;
}

.btn-reject {
  flex: 1;
  background: var(--color-white-dark);
  color: var(--color-gray-max);
  font-size: 28rpx;
  padding: 15rpx 0;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-gray);
  line-height: 1.2;
}

.btn-reject::after {
  border: none;
}

.empty-hint {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: var(--color-gray-max);
}

.load-more {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--color-gray-max);
}
