<!-- 禁用页面滚动（地图选点打开时） -->
<page-meta page-style="{{pageMetaStyle}}"></page-meta>

<!-- 格式化工具 WXS -->
<wxs module="fmt">
function fixed6(val) {
  if (val === undefined || val === null) return '--';
  return val.toFixed(6);
}
module.exports = {
  fixed6: fixed6
};
</wxs>

<block wx:if="{{auth}}">

  <!-- 校区管理 -->
  <view class='mainF-block'>
    <view class="campus-block">
      <view class="title">校区选项</view>
      <view class="container">
        <view class='category-box' wx:for="{{filters[0].category}}" wx:for-item="ctg" wx:for-index='cateindex' wx:key='name'>
          <view class='sub-option campus-row'>
            <view class='campus-info'>
              <view class='content'>{{ctg.name}}</view>
              <view class='coord-text' wx:if="{{campusCenterStrs[ctg.name]}}">{{campusCenterStrs[ctg.name]}}</view>
              <view class='coord-text unset' wx:else>未设置中心坐标</view>
            </view>
            <view class='campus-actions'>
              <button class='short' bindtap='openMapPicker' data-campus='{{ctg.name}}'>坐标</button>
              <button class='short' bindtap='deleteCampus' data-cateindex='{{cateindex}}'>删</button>
            </view>
          </view>
        </view>

        <form wx:if="{{addingCampus}}" bindsubmit="addCampusConfirm">
          <input class='content' name='name'></input>
          <button class='submit' form-type='submit'>确定</button>
        </form>
        <button wx:if='{{!addingCampus}}' class='long' bindtap='addCampus'>加校区</button>
      </view>
    </view>
  </view>

  <!-- 区域管理 -->
  <view class='mainF-block' wx:for='{{filters}}' wx:for-item='mainF' wx:for-index="filters_sub" wx:key='name'>
    <view class="title">{{mainF.name}}选项</view>
    <view class='container'>
      <view class='category-box' wx:for="{{mainF.category}}" wx:for-item="ctg" wx:for-index='cateindex' wx:key='name'>
        <view class="category">{{ctg.name}}</view>
        <view class='sub-option' wx:for="{{ctg.items}}" wx:for-index='innerindex' wx:key='name'>
          <view class='content'>{{item.name}}</view>
          <button class='short' bindtap='moveOption' data-innerindex='{{innerindex}}' data-cateindex='{{cateindex}}' data-filterssub='{{filters_sub}}' data-direct='up'>上</button>
          <button class='short' bindtap='moveOption' data-innerindex='{{innerindex}}' data-cateindex='{{cateindex}}' data-filterssub='{{filters_sub}}' data-direct='down'>下</button>
          <button class='short' bindtap='deleteOption' data-innerindex='{{innerindex}}' data-cateindex='{{cateindex}}' data-filterssub='{{filters_sub}}'>删</button>
        </view>
        <form wx:if="{{ctg.adding}}" data-filterssub='{{filters_sub}}' data-cateindex='{{cateindex}}' bindsubmit="addOptionConfirm">
          <input class='content' name='name'></input>
          <button class='submit' form-type='submit'>确定</button>
        </form>
        <button wx:if='{{!ctg.adding}}' class='long' bindtap='addOptionInput' data-filterssub='{{filters_sub}}' data-cateindex='{{cateindex}}'>加{{ctg.name}}选项</button>
      </view>
    </view>
  </view>
  <!-- 地图选点浮层 -->
  <map
    wx:if="{{mapPickerVisible}}"
    id="campusMapPicker"
    class="picker-map"
    latitude="{{mapPickerInitLat}}"
    longitude="{{mapPickerInitLng}}"
    scale="{{mapPickerScale}}"
    enable-zoom="{{false}}"
    enable-scroll="{{true}}"
    bindregionchange="onMapRegionChange"
    show-location="{{false}}"
  >
    <cover-view class="picker-crosshair">
      <cover-view class="crosshair-v"></cover-view>
      <cover-view class="crosshair-h"></cover-view>
    </cover-view>
    <!-- 缩放按钮 -->
    <cover-view class="picker-zoom-bar">
      <cover-view class="zoom-btn" bindtap="zoomMapIn">+</cover-view>
      <cover-view class="zoom-divider"></cover-view>
      <cover-view class="zoom-btn" bindtap="zoomMapOut">−</cover-view>
    </cover-view>
    <cover-view class="picker-top-bar">
      <cover-view class="picker-campus-label">{{mapPickerCampus}}</cover-view>
      <cover-view class="picker-coords-display">{{fmt.fixed6(mapPickerLat)}}, {{fmt.fixed6(mapPickerLng)}} | {{mapPickerScale}}级</cover-view>
    </cover-view>
    <cover-view class="picker-bottom-bar">
      <cover-view class="picker-btn cancel" bindtap="cancelMapPicker">取消</cover-view>
      <cover-view wx:if="{{mapPickerHasCenter}}" class="picker-btn delete" bindtap="deleteCampusCenter">删除坐标</cover-view>
      <cover-view class="picker-btn confirm" bindtap="confirmMapPicker">确定</cover-view>
    </cover-view>
  </map>

  <view class='bottom-bar'>
    <button class='bottom' bindtap='uploadFilters'>确定上传</button>
  </view>
</block>

<!-- 未授权提示 -->
<no-auth wx:else tip-text="{{tipText}}"></no-auth>