page { background: var(--color-white-dark); }
.header-bar { display: flex; justify-content: space-between; align-items: center; padding: 25rpx 30rpx; background: #fff; margin-bottom: 10rpx; }
.title { font-size: 34rpx; font-weight: 600; color: var(--color-black-min); }
.btn-add { width: auto; padding: 12rpx 30rpx; font-size: 26rpx; background: var(--color-primary); color: var(--color-primary-text); border-radius: 12rpx; border: none; line-height: 1.2; }
.btn-add::after { border: none; }
.icon-card { display: flex; align-items: center; background: #fff; margin: 0 20rpx 15rpx; border-radius: 12rpx; padding: 20rpx; }
.icon-img { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; }
.icon-info { flex: 1; display: flex; flex-direction: column; }
.icon-name { font-size: 30rpx; font-weight: 500; margin-bottom: 10rpx; }
.icon-toggle { display: flex; align-items: center; }
.toggle-label { font-size: 24rpx; color: var(--color-gray-max); margin-right: 10rpx; }
.btn-edit { width: auto; padding: 10rpx 24rpx; font-size: 24rpx; background: var(--color-white-dark); border: 1rpx solid var(--color-gray); border-radius: 8rpx; line-height: 1.2; }
.btn-edit::after { border: none; }
.empty-hint { text-align: center; padding: 80rpx 0; font-size: 28rpx; color: var(--color-gray-max); }
