.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.demo-badge {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  z-index: 100;
  background: rgba(0, 0, 0, 0.55);
  color: #ffd101;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.map-container {
  width: 100%;
  position: relative;
}

.campus-map {
  width: 100%;
  height: 100%;
}

.map-tip {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--color-black-transparent);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.map-empty {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 60rpx 50rpx;
  border-radius: 20rpx;
  box-shadow: 0 0 20rpx var(--color-gray);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-black-min);
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--color-gray-max);
}

/* 定位到校区按钮组（可折叠） */
.campus-btn-group {
  position: fixed;
  right: 24rpx;
  bottom: calc(15vh + 20rpx);
  z-index: 99;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0;
}

/* 折叠面板：校区按钮列表 */
.campus-btns-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  margin-bottom: 0;
  transition: max-height 0.3s ease, opacity 0.25s ease, margin-bottom 0.3s ease;
}

.campus-btns-panel.expanded {
  max-height: 600rpx;
  opacity: 1;
  margin-bottom: 12rpx;
}

.campus-btn {
  background: #fff;
  border-radius: 44rpx;
  padding: 14rpx 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: opacity 0.25s ease;
  align-self: flex-end;
}

.campus-btn:active {
  opacity: 0.75;
  background: #f5f5f5;
}

.campus-btn-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}

/* 折叠开关按钮 */
.campus-toggle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  font-size: 36rpx;
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

.campus-toggle:active {
  transform: scale(0.9);
  background: #f5f5f5;
}

/* 底部详情卡片 */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.detail-overlay.show {
  pointer-events: auto;
  opacity: 1;
}

.detail-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
}

.detail-card {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 0 30rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
  overflow-y: auto;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-handle {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 10rpx;
}

.handle-bar {
  width: 60rpx;
  height: 6rpx;
  background: var(--color-gray);
  border-radius: 3rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0 20rpx;
}

.detail-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-primary-text);
}

.detail-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--color-gray-max);
  border-radius: 50%;
  background: var(--color-gray-light);
}

.detail-photo-wrap {
  position: relative;
  margin-bottom: 20rpx;
  height: 360rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: var(--color-gray-normal);
}

.detail-photo {
  width: 100%;
  /* widthFix 让图片按宽度等比缩放，高度自适应（竖屏照片会很高） */
  /* 通过外层 overflow:hidden + animation 实现上下往返移动 */
  position: absolute;
  top: 0;
  left: 0;
  display: block;
  will-change: transform;
}

/* 竖屏照片自动上下往返：CSS animation infinite alternate 由渲染引擎驱动，
   无需 JS transitionend 切换方向，避免到顶/底时因 setData 异步导致的闪烁 */
.detail-photo.pan-animate {
  animation: panVertical var(--pan-duration, 6s) ease-in-out infinite alternate;
}

@keyframes panVertical {
  from { transform: translateY(0); }
  to   { transform: translateY(calc(var(--pan-distance, 0px) * -1)); }
}

.detail-location {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
}

.location-icon {
  margin-right: 6rpx;
  font-size: 20rpx;
}

.detail-info {
  background: var(--color-primary-light);
  border-radius: 12rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 25rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-label {
  font-size: 26rpx;
  color: var(--color-gray-max);
  flex-shrink: 0;
  min-width: 150rpx;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-black-min);
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
  word-break: break-all;
  text-align: right;
}

.gender-icon {
  width: 32rpx;
  height: 32rpx;
}

.detail-btn {
  width: 100%;
  background: var(--color-primary);
  color: var(--color-primary-text);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 20rpx 0;
  border: none;
  line-height: 1.2;
}

.detail-btn::after {
  border: none;
}

/* ===== 轨迹相关样式 ===== */

/* 详情卡内按钮组：查看轨迹 + 查看详情 并排 */
.detail-btn-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 25rpx;
}

/* 详情卡内「查看轨迹」按钮 */
.detail-trajectory-btn {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-primary, #4A90D9);
  background: var(--color-primary-light, #e8f4fd);
  border-radius: 44rpx;
  letter-spacing: 2rpx;
  min-width: 0;
}

.detail-trajectory-btn:active {
  opacity: 0.75;
  background: var(--color-primary, #4A90D9);
  color: #fff;
}

/* 查看详情按钮 - 并排时等宽 */
.detail-btn.primary.half {
  flex: 1;
  min-width: 0;
}

/* 地图右上角「还原」按钮 */
.restore-btn {
  position: fixed;
  top: 100rpx;
  right: 24rpx;
  z-index: 999;
  background: var(--color-primary);
  color: #fff;
  padding: 18rpx 32rpx;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.restore-btn:active {
  opacity: 0.8;
  background: var(--color-primary-dark, #dfb600);
}

/* 左下角：喵地图总猫猫数量（浅色字，固定） */
.total-cats-badge {
  position: fixed;
  left: 24rpx;
  bottom: calc(15vh + 20rpx);
  z-index: 99;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  pointer-events: none;
}

.total-cats-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #FF6B35;
  line-height: 1;
}

.total-cats-label {
  font-size: 24rpx;
  color: #8a8a8a;
  line-height: 1;
}

/* 轨迹时间线容器 */
.trajectory-timeline {
  max-height: 360rpx;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

/* 时间线单项 */
.tl-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-gray-light, #f0f0f0);
}

.tl-item:last-child {
  border-bottom: none;
}

.tl-item:active {
  background: var(--color-primary-light, #e8f4fd);
}

/* 时间线圆点 */
.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary, #4A90D9);
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 16rpx;
}

/* 时间线信息区 */
.tl-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 时间线日期文字 */
.tl-date {
  font-size: 26rpx;
  color: var(--color-black-min, #333);
  font-weight: 500;
}

/* 时间线坐标文字 */
.tl-coord {
  font-size: 22rpx;
  color: var(--color-gray-max, #999);
}
