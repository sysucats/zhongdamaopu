page {
  width: 750rpx;
  padding: 50rpx 30rpx 0 30rpx;
  box-sizing: border-box;
}
.userInfo {
  width: 100%;
  padding: 0rpx 0rpx 10rpx 0;
  display: flex;
}

.userInfo image {
  height: 50rpx;
  width: 50rpx;
  margin-right: 10rpx;
  border-radius: 5rpx;
}

.userInfo-cat {
  width: 520rpx;
}

.userInfo text {
  height: 50rpx;
  line-height: 50rpx;
  font-size: 32rpx;
}

.update-userInfo {
  font-size: 20rpx;
  line-height: 50rpx;
  color: var(--color-gray-dark);
  margin-left: auto;
}

.need-notice {
  width: 100%;
  padding: 0rpx 0rpx 30rpx 0;
  display: flex;
  align-items: center;
}

.need-notice .my-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 1rpx solid var(--color-gray-dark);
  border-radius: 20%;
  padding: 5rpx;
  display: inline-block;
  box-sizing: border-box;
}

.need-notice .my-checkbox .my-checkbox-core {
  width: 100%;
  height: 100%;
  border-radius: 20%;
  background-color: var(--color-gray-light);
}

.need-notice .my-checkbox.checked .my-checkbox-core {
  background-color: var(--color-primary);
}

.need-notice text {
  margin-left: 10rpx;
  height: 100%;
  line-height: 100%;
  font-size: 30rpx;
}

.card {
  box-shadow: 0 0 10rpx var(--color-gray-dark);
  padding: 30rpx 30rpx 15rpx 30rpx;
  margin: 30rpx 0;
  border-radius: 20rpx;
}

.selected-image {
  border-radius: 3rpx;
  width: 630rpx;
  height: 630rpx;
  background-color: var(--color-gray-dark);
  margin-bottom: 30rpx;
}

button {
  width: 300rpx;
  display: inline-block;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 40rpx;
  padding: 20rpx 30rpx;
  border: 1rpx solid var(--color-gray-max);
  border-radius: 15rpx;
  margin-top: 15rpx;
}

button.long {
  /* width: 690rpx; */
  width: 100%;
}

button.primary {
  background-color: var(--color-primary);
  color: var(--color-text-onPrimary);
}

button + button {
  margin-left: 30rpx;
  /* float: right; */
}


.label {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 5rpx;
  margin-left: 10rpx;
}

picker, input {
  border-bottom: 2rpx var(--color-primary) solid;
  background-color: var(--color-white-dark);
  padding: 15rpx;
  margin-bottom: 20rpx;
  color: var(--color-black-light);
}

/* 统一设置相关 */
.set-all {
  box-shadow: 0 0 10rpx var(--color-gray-max);
  padding: 30rpx 30rpx 20rpx 30rpx;
  margin: 20rpx 0;
  border-radius: 20rpx;
}

.set-all .title {
  width: 100%;
  text-align: center;
  font-size: 36rpx;
}

.tip {
  font-size: 24rpx;
  margin-bottom: 5rpx;
}

/* 地图标记图标选择 */
.marker-box {
  box-shadow: 0 0 10rpx var(--color-gray-dark);
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
  border-radius: 20rpx;
  background: var(--color-primary-light);
}

.marker-header {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--color-black-min);
}

.marker-scroll {
  white-space: nowrap;
  width: 100%;
}

.marker-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  padding: 12rpx 10rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  background: #fff;
}

.marker-item.selected {
  border-color: var(--color-primary);
  background: #fffdf0;
}

.marker-item image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.marker-item text {
  font-size: 22rpx;
  color: var(--color-black-min);
  margin-top: 6rpx;
}

/* 位置信息 */
.location-box {
  box-shadow: 0 0 10rpx var(--color-gray-dark);
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
  border-radius: 20rpx;
  background: var(--color-primary-light);
}

.location-header {
  margin-bottom: 12rpx;
}

.location-notice {
  display: block;
  font-size: 22rpx;
  color: #e67e22;
  margin-top: 6rpx;
  line-height: 1.5;
}

.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.location-tip {
  font-size: 26rpx;
  color: var(--color-gray-max);
}

.location-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 16rpx;
}

.location-name {
  font-size: 26rpx;
  color: var(--color-black-light);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.location-coords {
  font-size: 22rpx;
  color: var(--color-gray-max);
}

.location-btn {
  width: 160rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  margin: 0;
  border-radius: 20rpx;
  background: var(--color-primary);
  color: var(--color-primary-text);
  border: none;
  line-height: 1.2;
  flex-shrink: 0;
}

.location-clear-row {
  margin-top: 10rpx;
  text-align: right;
}

.location-clear {
  font-size: 22rpx;
  color: var(--color-gray-max, #999);
  text-decoration: underline;
}

/* ========== 地图选点浮层 ========== */
.picker-map {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

/* 十字准星 */
.picker-crosshair {
  position: fixed;
  top: 50%;
  left: 50%;
  margin-left: -30rpx;
  margin-top: -30rpx;
  width: 60rpx;
  height: 60rpx;
  pointer-events: none;
}

.crosshair-v {
  position: absolute;
  left: 50%;
  top: 0;
  width: 4rpx;
  height: 100%;
  background: #E74C3C;
  margin-left: -2rpx;
  border-radius: 2rpx;
}

.crosshair-h {
  position: absolute;
  top: 50%;
  left: 0;
  height: 4rpx;
  width: 100%;
  background: #E74C3C;
  margin-top: -2rpx;
  border-radius: 2rpx;
}

/* 顶部信息栏 */
.picker-top-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  padding: 60rpx 30rpx 20rpx 30rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, transparent 100%);
  box-sizing: border-box;
  pointer-events: none;
}

.picker-coords-display {
  font-size: 24rpx;
  color: #EEEEEE;
  margin-top: 8rpx;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.5);
}

/* 缩放按钮 */
.picker-zoom-bar {
  position: fixed;
  right: 24rpx;
  top: 50%;
  margin-top: -80rpx;
  width: 72rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.15);
  overflow: hidden;
}

.zoom-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 300;
  color: #333333;
  background: transparent;
}

.zoom-divider {
  width: 52rpx;
  height: 1rpx;
  background: #E0E0E0;
  margin: 0 auto;
}

/* 底部操作栏 */
.picker-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom)) 30rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, transparent 100%);
}

.picker-btn {
  width: 44%;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.picker-btn.cancel {
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
}

.picker-btn.confirm {
  background: #07C160;
  color: #FFFFFF;
}