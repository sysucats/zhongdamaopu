page {
  width: 750rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: var(--color-gray-max, #999);
  font-size: 28rpx;
}

/* 状态卡片 */
.status-card {
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.status-card.approved {
  background: #e8f8e8;
  border: 2rpx solid #27ae60;
}

.status-card.pending {
  background: #fff8e1;
  border: 2rpx solid #f5a623;
}

.status-card.rejected {
  background: #fde8e8;
  border: 2rpx solid #e74c3c;
}

.status-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.status-detail {
  font-size: 26rpx;
  color: var(--color-black-min, #666);
  margin-top: 8rpx;
  line-height: 1.6;
}

.status-hint {
  font-size: 26rpx;
  color: var(--color-black-min, #666);
  margin-top: 20rpx;
  line-height: 1.6;
}

.reapply-btn {
  margin-top: 30rpx;
}

.reapply-btn button {
  background-color: var(--color-primary);
  color: var(--color-text-onPrimary);
  font-size: 30rpx;
  padding: 16rpx 40rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 1.2;
}

.reapply-btn button::after {
  border: none;
}

/* 申请条件 */
.requirement-box {
  background: var(--color-primary-light);
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.req-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary-text);
  margin-bottom: 12rpx;
}

.req-desc {
  font-size: 26rpx;
  color: var(--color-black-min);
  margin-bottom: 12rpx;
}

.req-stats {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
  margin-bottom: 10rpx;
}

.req-status.unmet {
  font-size: 24rpx;
  color: var(--color-red, #e74c3c);
  margin-top: 8rpx;
}

.req-status.met {
  font-size: 24rpx;
  color: var(--color-green, #27ae60);
  margin-top: 8rpx;
}

/* 自动通过规则 */
.auto-pass-box {
  background: #f0f4ff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #d0d9f0;
}

.auto-pass-box.active {
  background: #e6f7e6;
  border: 2rpx solid #27ae60;
}

.auto-pass-desc {
  font-size: 26rpx;
  color: var(--color-black-min, #666);
  margin-top: 8rpx;
  line-height: 1.6;
}

/* 输入区域 */
.inputTitle {
  margin-left: 15rpx;
  font-size: 30rpx;
}

textarea {
  width: 650rpx;
  height: 10rem;
  border-bottom: 2rpx var(--color-primary) solid;
  background-color: var(--color-white-dark);
  padding: 20rpx;
  color: var(--color-black-light);
  margin-top: 8rpx;
  font-size: 28rpx;
}

.lengthTips {
  font-size: 26rpx;
  color: var(--color-gray-max);
  float: right;
  margin-right: 10rpx;
  margin-top: 5rpx;
}

.submitButton {
  margin-top: 30rpx;
}

.submitButton button {
  background-color: var(--color-primary);
  color: var(--color-text-onPrimary);
  width: 100%;
  font-size: 35rpx;
  padding: 20rpx 30rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 1.2;
}

.submitButton button::after {
  border: none;
}

.footnote {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-gray-max);
  text-align: center;
}
